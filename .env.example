# Required: Bybit V5 API credentials
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Recommended: Start with testnet (default: true)
# Set to false only when you are ready to trade real funds
BYBIT_TESTNET=true

# Options module (default: false)
ENABLE_OPTIONS=false

# Options: allow naked short selling (default: false)
# Naked short options carry unlimited or very large maximum loss.
OPTIONS_ALLOW_NAKED_SHORT=false

# Options: max premium as percentage of USDC balance (default: no cap)
# OPTIONS_MAX_PREMIUM_PCT_BALANCE=10
